x-common-env: &common-env
  TZ: ${TZ}
  PUID: ${PUID}
  PGID: ${PGID}
x-logging: &common-log
  driver: "json-file"
  options:
    tag: "{{.ImageName}}|{{.Name}}|{{.ImageFullID}}|{{.FullID}}"
volumes:
  prometheus_data: {}
services:
  deluge:
    image: lscr.io/linuxserver/deluge:2.2.0-r1-ls364
    container_name: deluge
    environment: *common-env
    volumes:
      - ${ROOT}/config/deluge:/config
      - ${ROOT}/downloads:/downloads
    ports:
      - 8112:8112
      - 6881:6881
      - 6881:6881/udp
    restart: unless-stopped
    logging: *common-log
  jackett:
    image: lscr.io/linuxserver/jackett
    container_name: jackett
    environment: *common-env
    volumes:
      - ${ROOT}/config/jackett:/config
      - ${ROOT}/downloads/blackhole:/downloads
    ports:
      - 9117:9117
    restart: unless-stopped
    logging: *common-log
  sonarr:
    image: lscr.io/linuxserver/sonarr
    container_name: sonarr
    environment: *common-env
    volumes:
      - ${ROOT}/config/sonarr:/config
      - ${ROOT}/complete/tv:/tv
      - ${ROOT}/downloads:/downloads
    ports:
      - 8989:8989
    restart: unless-stopped
    logging: *common-log
  radarr:
    image: lscr.io/linuxserver/radarr
    container_name: radarr
    environment: *common-env
    volumes:
      - ${ROOT}/config/radarr:/config
      - ${ROOT}/complete/movies:/movies
      - ${ROOT}/downloads:/downloads
    ports:
      - 7878:7878
    restart: unless-stopped
    logging: *common-log
  bazarr:
    image: lscr.io/linuxserver/bazarr
    container_name: bazarr
    environment: *common-env
    volumes:
      - ${ROOT}/config/bazarr:/config
      - ${ROOT}/complete/movies:/movies
      - ${ROOT}/complete/tv:/tv
    ports:
      - 6767:6767
    restart: unless-stopped
    logging: *common-log
  plex:
    image: lscr.io/linuxserver/plex
    container_name: plex
    environment:
      <<: *common-env
      VERSION: docker
    hostname: raspberrypi
    volumes:
      - ${ROOT}/config/plex:/config
      - ${ROOT}/complete/tv:/tv
      - ${ROOT}/complete/movies:/movies
    ports:
      # for access to the Plex Media Server [required]
      - "32400:32400"
      # for access to the Plex DLNA Server
      - "1900:1900/udp"
      - "32469:32469"
      # for controlling Plex Home Theater via Plex Companion
      - "3005:3005"
      # for older Bonjour/Avahi network discovery
      # - "5353:5353/udp"
      # for controlling Plex for Roku via Plex Companion
      - "8324:8324"
      # for current GDM network discovery
      - "32410:32410/udp"
      - "32412:32412/udp"
      - "32413:32413/udp"
      - "32414:32414/udp"
    restart: unless-stopped
    logging: *common-log
  portainer:
    image: portainer/portainer-ce:2.31.0
    container_name: portainer
    environment: *common-env
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
      - ${ROOT}/config/portainer:/data
    ports:
      - 9000:9000
    restart: always
    logging: *common-log
  organizr:
    image: ghcr.io/organizr/organizr
    container_name: organizr
    environment: *common-env
    volumes:
      - ${ROOT}/config/organizr:/config
    ports:
      - 80:80
    restart: always
    logging: *common-log
